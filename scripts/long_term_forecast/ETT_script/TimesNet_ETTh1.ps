$ErrorActionPreference = "Stop"

$python = (Get-Command python -ErrorAction Stop).Source
$env:CUDA_VISIBLE_DEVICES = "0"

$predLens = 96, 192, 336, 720

foreach ($predLen in $predLens) {
    & $python -u run.py `
        --task_name long_term_forecast `
        --is_training 1 `
        --root_path ./dataset/ETT-small/ `
        --data_path ETTh1.csv `
        --model_id "ETTh1_96_$predLen" `
        --model TimesNet `
        --data ETTh1 `
        --features M `
        --seq_len 96 `
        --label_len 48 `
        --pred_len $predLen `
        --e_layers 2 `
        --d_layers 1 `
        --factor 3 `
        --enc_in 7 `
        --dec_in 7 `
        --c_out 7 `
        --d_model 16 `
        --d_ff 32 `
        --des Exp `
        --itr 1 `
        --top_k 5

    if ($LASTEXITCODE -ne 0) {
        throw "Run failed for pred_len=$predLen with exit code $LASTEXITCODE"
    }
}
